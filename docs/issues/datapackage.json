{
  "name": "mission-control",
  "resources": [
    {
      "name": "mission",
      "path": "mission.usv",
      "format": "csv",
      "delimiter": "\u001f",
      "schema": {
        "fields": [
          { "name": "slug", "type": "string" },
          { "name": "priority", "type": "integer" },
          { "name": "status", "type": "string" },
          { "name": "branch", "type": "string" }
        ]
      }
    }
  ]
}
